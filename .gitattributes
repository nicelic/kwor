# 统一换行处理,防止 Windows 开发时把 LF 误转成 CRLF
# 默认让 git 自行判断文本/二进制
* text=auto

# 这些文件在 Linux 上执行/解析,必须保持 LF,否则 \r 会导致运行失败
*.sh        text eol=lf
*.bash      text eol=lf
entrypoint.sh   text eol=lf
Dockerfile* text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.service   text eol=lf
*.mjs       text eol=lf

# Windows 批处理/PowerShell 保持 CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# 常见二进制类型,禁止换行转换
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.tar.gz    binary
*.zip       binary
*.exe       binary
